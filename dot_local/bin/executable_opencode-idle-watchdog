#!/usr/bin/env python3
"""Wait until other opencode sessions go idle, then optionally run a command."""

from __future__ import annotations

import argparse
import base64
from dataclasses import dataclass
import datetime as dt
import fcntl
import json
import os
from pathlib import Path
import re
import shlex
import signal
import subprocess
import sys
import time
import urllib.request


APP_NAME = "opencode-idle-watchdog"
DEFAULT_CHECK_INTERVAL_SECONDS = 180
DEFAULT_REQUIRED_IDLE_CHECKS = 3
HTTP_TIMEOUT_SECONDS = 2

HOME = Path.home()
CACHE_HOME = Path(os.environ.get("XDG_CACHE_HOME", HOME / ".cache"))
STATE_DIR = CACHE_HOME / APP_NAME
LOCK_PATH = STATE_DIR / "watchdog.lock"
PID_PATH = STATE_DIR / "watchdog.pid"
LOG_PATH = STATE_DIR / "watchdog.log"
PROC = Path("/proc")

OPENCODE_BUSY_FOOTER_TEXT = "esc interrupt"


@dataclass(frozen=True, slots=True)
class OpencodeProcess:
    pid: int
    argv: tuple[str, ...]
    env: dict[str, str]


class Terminated(RuntimeError):
    pass


def raise_terminated(_signum: int, _frame: object) -> None:
    raise Terminated


def log(message: str) -> None:
    line = f"[{dt.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}] {message}"
    print(line, flush=True)
    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        with LOG_PATH.open("a", encoding="utf-8") as file:
            file.write(line + "\n")
    except OSError:
        pass


def read_text(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return ""


def proc_uid(pid: int) -> int | None:
    for line in read_text(PROC / str(pid) / "status").splitlines():
        if line.startswith("Uid:"):
            try:
                return int(line.split()[1])
            except (IndexError, ValueError):
                return None
    return None


def proc_environ(pid: int) -> dict[str, str]:
    return dict(
        item.split("=", 1)
        for item in read_text(PROC / str(pid) / "environ").split("\0")
        if item and "=" in item
    )


def proc_identity(pid: int) -> tuple[str, int] | None:
    stat = read_text(PROC / str(pid) / "stat")
    start = stat.find("(")
    end = stat.rfind(")")
    if start < 0 or end < start:
        return None
    try:
        return stat[start + 1 : end], int(stat[end + 2 :].split()[1])
    except (IndexError, ValueError):
        return None


def opencode_processes() -> list[OpencodeProcess]:
    uid = os.getuid()
    processes = []
    for name in os.listdir(PROC):
        if not name.isdigit():
            continue
        pid = int(name)
        identity = proc_identity(pid)
        if identity is None or identity[0] != "opencode" or proc_uid(pid) != uid:
            continue
        processes.append(
            OpencodeProcess(
                pid,
                tuple(
                    arg
                    for arg in read_text(PROC / name / "cmdline").split("\0")
                    if arg
                ),
                proc_environ(pid),
            )
        )
    return sorted(processes, key=lambda process: process.pid)


def ancestor_opencode_pid() -> int | None:
    pid = os.getpid()
    seen: set[int] = set()
    while pid > 1 and pid not in seen:
        seen.add(pid)
        identity = proc_identity(pid)
        if identity is None:
            return None
        comm, parent_pid = identity
        if comm == "opencode":
            return pid
        pid = parent_pid
    return None


def normalize_tty(tty: str) -> str | None:
    tty = tty.strip()
    if not tty or tty == "?":
        return None
    return tty if tty.startswith("/dev/") else f"/dev/{tty}"


def pid_tty(pid: int | None) -> str | None:
    if pid is None:
        return None
    try:
        result = subprocess.run(
            ["/usr/bin/ps", "-o", "tty=", "-p", str(pid)],
            check=False,
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    return normalize_tty(result.stdout)


def exclusion_context() -> tuple[int | None, str | None, str | None]:
    configured_pid = os.environ.get("WATCHDOG_EXCLUDE_OPENCODE_PID", "").strip()
    excluded_pid = (
        int(configured_pid) if configured_pid.isdigit() else ancestor_opencode_pid()
    )

    excluded_run_id = (
        os.environ.get("WATCHDOG_EXCLUDE_OPENCODE_RUN_ID", "").strip()
        or os.environ.get("OPENCODE_RUN_ID", "").strip()
        or (proc_environ(excluded_pid).get("OPENCODE_RUN_ID") if excluded_pid else None)
    )
    excluded_tty = normalize_tty(os.environ.get("WATCHDOG_EXCLUDE_TTY", "")) or pid_tty(
        excluded_pid
    )
    return excluded_pid, excluded_run_id or None, excluded_tty


def command_stdout(args: list[str], timeout: int) -> str | None:
    try:
        result = subprocess.run(
            args, check=False, capture_output=True, text=True, timeout=timeout
        )
    except (OSError, subprocess.TimeoutExpired) as exc:
        log(f"command failed: {' '.join(args)}: {exc}")
        return None
    return result.stdout if result.returncode == 0 else None


def wezterm_pane_blockers(excluded_tty: str | None) -> list[str]:
    pane_list = command_stdout(["wezterm", "cli", "list", "--format", "json"], 10)
    if pane_list is None:
        return []
    try:
        panes = json.loads(pane_list)
    except json.JSONDecodeError as exc:
        log(f"could not parse wezterm pane list: {exc}")
        return []
    if not isinstance(panes, list):
        log("could not parse wezterm pane list: expected a list")
        return []

    blockers = []
    for pane in panes:
        if not isinstance(pane, dict):
            continue
        tty = normalize_tty(str(pane.get("tty_name") or ""))
        if tty and tty == excluded_tty:
            continue

        title = " ".join(
            str(pane.get(key) or "") for key in ("title", "tab_title", "window_title")
        ).strip()
        if "OC |" not in title and "mightyminions" not in str(pane.get("cwd") or ""):
            continue

        pane_id = pane.get("pane_id")
        if pane_id is None:
            log("skipping wezterm pane without pane_id")
            continue

        text = command_stdout(
            ["wezterm", "cli", "get-text", "--pane-id", str(pane_id), "--start-line", "-80"],
            10,
        )
        if text is None:
            continue

        line = next(
            (
                line.strip()
                for line in text.splitlines()
                if OPENCODE_BUSY_FOOTER_TEXT in line.lower()
            ),
            None,
        )
        if line:
            blockers.append(
                f"pane {pane_id} {tty or ''} {OPENCODE_BUSY_FOOTER_TEXT} "
                f"line={line[:120]!r} title={title[:80]}"
            )
    return blockers


def arg_value(argv: tuple[str, ...], name: str) -> str | None:
    prefix = name + "="
    for index, arg in enumerate(argv):
        if arg.startswith(prefix):
            return arg[len(prefix) :]
        if arg == name and index + 1 < len(argv):
            return argv[index + 1]
    return None


def local_probe_host(host: str | None) -> str:
    if not host or host in {"0.0.0.0", "::", "[::]"}:
        return "127.0.0.1"
    return host.strip("[]")


def tcp4_listeners() -> dict[str, tuple[str, int]]:
    listeners: dict[str, tuple[str, int]] = {}
    for line in read_text(PROC / "net" / "tcp").splitlines()[1:]:
        fields = line.split()
        if len(fields) < 10 or fields[3] != "0A":
            continue
        address, port_hex = fields[1].split(":", 1)
        try:
            host = ".".join(
                str(int(address[index : index + 2], 16)) for index in range(6, -1, -2)
            )
            port = int(port_hex, 16)
        except ValueError:
            continue
        listeners[fields[9]] = (local_probe_host(host), port)
    return listeners


def socket_inodes(pid: int) -> set[str]:
    fd_dir = PROC / str(pid) / "fd"
    try:
        names = os.listdir(fd_dir)
    except OSError:
        return set()

    inodes: set[str] = set()
    for name in names:
        try:
            target = os.readlink(fd_dir / name)
        except OSError:
            continue
        if match := re.fullmatch(r"socket:\[(\d+)\]", target):
            inodes.add(match.group(1))
    return inodes


def opencode_api_urls(
    processes: list[OpencodeProcess],
) -> list[tuple[OpencodeProcess, str]]:
    urls = []
    for proc in processes:
        port = arg_value(proc.argv, "--port")
        host = local_probe_host(arg_value(proc.argv, "--hostname") or "127.0.0.1")
        if port and port.isdigit() and int(port) > 0:
            urls.append((proc, f"http://{host}:{int(port)}"))
        elif "serve" in proc.argv:
            urls.append((proc, "http://127.0.0.1:4096"))

    listeners = tcp4_listeners()
    for proc in processes:
        for inode in socket_inodes(proc.pid):
            if endpoint := listeners.get(inode):
                host, port = endpoint
                urls.append((proc, f"http://{host}:{port}"))
    return urls


def auth_header(proc: OpencodeProcess) -> str | None:
    password = proc.env.get("OPENCODE_SERVER_PASSWORD") or os.environ.get(
        "OPENCODE_SERVER_PASSWORD"
    )
    if not password:
        return None
    username = (
        proc.env.get("OPENCODE_SERVER_USERNAME")
        or os.environ.get("OPENCODE_SERVER_USERNAME")
        or "opencode"
    )
    token = base64.b64encode(f"{username}:{password}".encode("utf-8")).decode("ascii")
    return f"Basic {token}"


def get_json(url: str, path: str, auth: str | None) -> object | None:
    request = urllib.request.Request(url.rstrip("/") + path)
    request.add_header("Accept", "application/json")
    if auth:
        request.add_header("Authorization", auth)
    try:
        with urllib.request.urlopen(request, timeout=HTTP_TIMEOUT_SECONDS) as response:
            body = response.read(1024 * 1024).decode("utf-8", errors="replace")
        return json.loads(body)
    except (OSError, ValueError):
        return None


def opencode_api_blockers(processes: list[OpencodeProcess]) -> list[str]:
    blockers = []
    seen: set[tuple[int, str]] = set()
    for proc, url in opencode_api_urls(processes):
        if (proc.pid, url) in seen:
            continue
        seen.add((proc.pid, url))

        auth = auth_header(proc)
        health = get_json(url, "/global/health", auth)
        if not isinstance(health, dict) or health.get("healthy") is not True:
            continue
        status = get_json(url, "/session/status", auth)
        if not isinstance(status, dict):
            continue

        active = [
            (session_id, value)
            for session_id, value in status.items()
            if not isinstance(value, dict) or value.get("type") != "idle"
        ]
        if active:
            sessions = []
            for session_id, value in active[:4]:
                status_type = (
                    value.get("type", "unknown")
                    if isinstance(value, dict)
                    else "unknown"
                )
                sessions.append(f"{session_id}:{status_type}")
            blockers.append(f"pid={proc.pid} {url} {' '.join(sessions)}")
    return blockers


def summarize(items: list[str], limit: int) -> str:
    parts = items[:limit]
    if len(items) > limit:
        parts.append(f"... +{len(items) - limit} more")
    return " | ".join(parts)


def current_blockers(
    excluded_pid: int | None,
    excluded_run_id: str | None,
    excluded_tty: str | None,
) -> list[tuple[str, str]]:
    processes = [
        proc
        for proc in opencode_processes()
        if proc.pid != excluded_pid
        and not (excluded_run_id and proc.env.get("OPENCODE_RUN_ID") == excluded_run_id)
    ]
    api_blockers = opencode_api_blockers(processes)
    pane_blockers = wezterm_pane_blockers(excluded_tty)

    blockers: list[tuple[str, str]] = []
    if api_blockers:
        blockers.append(
            (
                "opencode API session status",
                f"opencode_api_blockers: {summarize(api_blockers, 5)}",
            )
        )
    if pane_blockers:
        blockers.append(
            ("active pane text", f"pane_blockers: {summarize(pane_blockers, 6)}")
        )
    return blockers


def pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def read_pid() -> int | None:
    text = read_text(PID_PATH).strip()
    return int(text) if text.isdigit() else None


def status() -> int:
    pid = read_pid()
    print(f"running={bool(pid and pid_alive(pid))} pid={pid or 'unknown'}")
    print(f"cache={STATE_DIR}")
    print(f"log={LOG_PATH}")
    if LOG_PATH.exists():
        lines = read_text(LOG_PATH).splitlines()[-8:]
        if lines:
            print("last log lines:")
            for line in lines:
                print(line)
    return 0


def stop_running() -> int:
    pid = read_pid()
    if not pid or not pid_alive(pid):
        print("watchdog is not running")
        return 0
    os.kill(pid, signal.SIGTERM)
    for _ in range(50):
        if not pid_alive(pid):
            print(f"stopped watchdog pid={pid}")
            return 0
        time.sleep(0.1)
    print(f"watchdog pid={pid} did not stop after SIGTERM")
    return 1


def detach(argv: list[str], command: list[str]) -> int:
    excluded_pid, excluded_run_id, excluded_tty = exclusion_context()
    command_index = len(argv) - len(command)
    child_args = [
        sys.argv[0],
        *(arg for arg in argv[:command_index] if arg != "--detach"),
        *argv[command_index:],
    ]

    env = os.environ.copy()
    if excluded_pid is not None:
        env["WATCHDOG_EXCLUDE_OPENCODE_PID"] = str(excluded_pid)
    if excluded_run_id:
        env["WATCHDOG_EXCLUDE_OPENCODE_RUN_ID"] = excluded_run_id
    if excluded_tty:
        env["WATCHDOG_EXCLUDE_TTY"] = excluded_tty

    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with Path("/dev/null").open("rb") as stdin, Path("/dev/null").open("ab") as output:
        proc = subprocess.Popen(
            child_args,
            stdin=stdin,
            stdout=output,
            stderr=output,
            start_new_session=True,
            env=env,
        )
    print(f"started {APP_NAME} pid={proc.pid}")
    print(f"log={LOG_PATH}")
    return 0


def run_watchdog(args: argparse.Namespace) -> int:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with LOCK_PATH.open("w", encoding="utf-8") as lock_file:
        try:
            fcntl.flock(lock_file, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            log(f"another watchdog already holds {LOCK_PATH}; exiting")
            return 0

        PID_PATH.write_text(str(os.getpid()), encoding="utf-8")
        excluded_pid, excluded_run_id, excluded_tty = exclusion_context()
        log(
            "watchdog started; "
            f"excluding opencode pid={excluded_pid or 'unknown'} "
            f"run_id={excluded_run_id or 'unknown'} tty={excluded_tty or 'unknown'}; "
            f"interval={args.interval}s required_idle_checks={args.required_idle_checks}; "
            f"cache={STATE_DIR}"
        )

        idle_checks = 0
        check_number = 0
        try:
            while True:
                check_number += 1

                blockers = current_blockers(excluded_pid, excluded_run_id, excluded_tty)
                blocker_names = [name for name, _detail in blockers]
                idle_checks = 0 if blockers else idle_checks + 1

                log(
                    f"check {check_number}: idle={idle_checks}/{args.required_idle_checks}; "
                    f"blockers={', '.join(blocker_names) if blocker_names else 'none'}"
                )
                for _name, detail in blockers:
                    log(detail)

                if idle_checks >= args.required_idle_checks:
                    log("idle confirmed")
                    break
                time.sleep(args.interval)
        finally:
            if read_pid() == os.getpid():
                try:
                    PID_PATH.unlink()
                except OSError:
                    pass

    if not args.command:
        return 0
    log(f"running command: {shlex.join(args.command)}")
    try:
        result = subprocess.run(args.command, check=False)
    except OSError as exc:
        log(f"could not run command: {exc}")
        return 127
    log(f"command exited with status {result.returncode}")
    return result.returncode


def positive_int(value: str) -> int:
    number = int(value)
    if number < 1:
        raise argparse.ArgumentTypeError("must be at least 1")
    return number


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Wait until all other opencode sessions go idle, then optionally run a command."
        ),
        allow_abbrev=False,
    )
    actions = parser.add_mutually_exclusive_group()
    actions.add_argument("--detach", action="store_true", help="start in the background")
    actions.add_argument("--status", action="store_true", help="show current watchdog status")
    actions.add_argument("--stop", action="store_true", help="stop the running watchdog")
    parser.add_argument(
        "--interval",
        type=positive_int,
        default=DEFAULT_CHECK_INTERVAL_SECONDS,
        help="seconds between checks (default: %(default)s)",
    )
    parser.add_argument(
        "--required-idle-checks",
        type=positive_int,
        default=DEFAULT_REQUIRED_IDLE_CHECKS,
        help="consecutive idle checks before exiting successfully (default: %(default)s)",
    )
    parser.add_argument("command", nargs=argparse.REMAINDER, help="command to run after idle")
    args = parser.parse_args(argv)
    if args.command[:1] == ["--"]:
        args.command = args.command[1:]
    if args.detach and not args.command:
        parser.error("--detach requires a command")
    if (args.status or args.stop) and args.command:
        parser.error("a command cannot be used with --status or --stop")
    return args


def main(argv: list[str]) -> int:
    signal.signal(signal.SIGTERM, raise_terminated)
    args = parse_args(argv)
    if args.status:
        return status()
    if args.stop:
        return stop_running()
    if args.detach:
        return detach(argv, args.command)
    return run_watchdog(args)


if __name__ == "__main__":
    try:
        raise SystemExit(main(sys.argv[1:]))
    except Terminated:
        log("watchdog terminated")
        raise SystemExit(143)
    except KeyboardInterrupt:
        log("watchdog interrupted")
        raise SystemExit(130)
    except Exception as exc:
        log(f"watchdog crashed: {exc!r}")
        raise
