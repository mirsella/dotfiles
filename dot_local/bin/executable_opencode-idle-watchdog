#!/usr/bin/env -S cargo +nightly -Zscript
---
[package]
edition = "2024"

[dependencies]
anyhow = "1.0.98"
base64 = "0.22.1"
chrono = { version = "0.4.41", default-features = false, features = ["clock"] }
clap = { version = "4.6.2", features = ["derive"] }
fs2 = "0.4.3"
libc = "0.2.174"
serde_json = "1.0.141"
signal-hook = "0.3.18"
ureq = { version = "3.3.0", default-features = false }
wait-timeout = "0.2.1"
---

//! Run a command after every other opencode session has gone idle.

use std::collections::{HashMap, HashSet};
use std::env;
use std::ffi::OsString;
use std::fs::{self, File, OpenOptions};
use std::io::{self, Read, Write};
use std::os::unix::fs::MetadataExt;
use std::os::unix::process::{CommandExt, ExitStatusExt};
use std::path::{Path, PathBuf};
use std::process::{Child, Command, Stdio};
use std::sync::mpsc::{self, Receiver};
use std::thread::{self, JoinHandle};
use std::time::Duration;

use anyhow::{Context, Result};
use base64::Engine;
use chrono::Local;
use clap::Parser;
use fs2::FileExt;
use serde_json::Value;
use signal_hook::{
    consts::{SIGINT, SIGTERM},
    iterator::{Handle as SignalHandle, Signals},
};
use wait_timeout::ChildExt;

const NAME: &str = "opencode-idle-watchdog";
const DEFAULT_INTERVAL: u64 = 180;
const DEFAULT_IDLE_CHECKS: u32 = 3;
const BUSY_PANE_TEXT: &str = "esc interrupt";

#[derive(Parser)]
#[command(
    about = "Wait until all other opencode sessions go idle, then optionally run a command.",
    trailing_var_arg = true,
    args_override_self = true
)]
struct Options {
    #[arg(long, conflicts_with_all = ["status", "stop"], requires = "command")]
    detach: bool,

    #[arg(long, conflicts_with_all = ["detach", "stop"])]
    status: bool,

    #[arg(long, conflicts_with_all = ["detach", "status"])]
    stop: bool,

    #[arg(long, default_value_t = DEFAULT_INTERVAL, value_parser = positive_u64)]
    interval: u64,

    #[arg(long, default_value_t = DEFAULT_IDLE_CHECKS, value_parser = positive_u32)]
    required_idle_checks: u32,

    #[arg(
        value_name = "COMMAND",
        num_args = 0..,
        conflicts_with_all = ["status", "stop"]
    )]
    command: Vec<OsString>,
}

struct State {
    root: PathBuf,
    lock_file: PathBuf,
    pid_file: PathBuf,
    log_file: PathBuf,
}

impl State {
    fn discover() -> Result<Self> {
        let home = env::var_os("HOME").context("HOME is not set")?;
        let cache = env::var_os("XDG_CACHE_HOME")
            .map(PathBuf::from)
            .unwrap_or_else(|| PathBuf::from(home).join(".cache"));
        let root = cache.join(NAME);
        Ok(Self {
            lock_file: root.join("watchdog.lock"),
            pid_file: root.join("watchdog.pid"),
            log_file: root.join("watchdog.log"),
            root,
        })
    }

    fn log(&self, message: impl AsRef<str>) {
        let line = format!(
            "[{}] {}",
            Local::now().format("%Y-%m-%d %H:%M:%S"),
            message.as_ref()
        );
        println!("{line}");
        let _ = io::stdout().flush();
        if fs::create_dir_all(&self.root).is_ok()
            && let Ok(mut file) = OpenOptions::new()
                .create(true)
                .append(true)
                .open(&self.log_file)
        {
            let _ = writeln!(file, "{line}");
        }
    }

    fn read_pid(&self) -> Option<i32> {
        fs::read_to_string(&self.pid_file)
            .ok()?
            .trim()
            .parse::<i32>()
            .ok()
            .filter(|pid| *pid > 0)
    }
}

struct Instance<'a> {
    state: &'a State,
    pid: i32,
    _lock: File,
}

impl<'a> Instance<'a> {
    fn acquire(state: &'a State) -> Result<Option<Self>> {
        fs::create_dir_all(&state.root)
            .with_context(|| format!("create {}", state.root.display()))?;
        let lock = OpenOptions::new()
            .create(true)
            .write(true)
            .truncate(false)
            .open(&state.lock_file)
            .with_context(|| format!("open {}", state.lock_file.display()))?;
        if let Err(error) = lock.try_lock_exclusive() {
            if error.kind() == io::ErrorKind::WouldBlock {
                state.log(format!(
                    "another watchdog already holds {}; exiting",
                    state.lock_file.display()
                ));
                return Ok(None);
            }
            return Err(error).context("lock watchdog instance");
        }

        let pid = std::process::id() as i32;
        fs::write(&state.pid_file, pid.to_string())
            .with_context(|| format!("write {}", state.pid_file.display()))?;
        Ok(Some(Self {
            state,
            pid,
            _lock: lock,
        }))
    }
}

impl Drop for Instance<'_> {
    fn drop(&mut self) {
        if self.state.read_pid() == Some(self.pid) {
            let _ = fs::remove_file(&self.state.pid_file);
        }
    }
}

struct Cancellation {
    receiver: Receiver<i32>,
    handle: SignalHandle,
    worker: Option<JoinHandle<()>>,
}

impl Cancellation {
    fn new() -> Result<Self> {
        let mut signals = Signals::new([SIGINT, SIGTERM]).context("install signal handlers")?;
        let handle = signals.handle();
        let (sender, receiver) = mpsc::channel();
        let worker = thread::spawn(move || {
            for signal in signals.forever() {
                if sender.send(signal).is_err() {
                    break;
                }
            }
        });
        Ok(Self {
            receiver,
            handle,
            worker: Some(worker),
        })
    }

    fn wait(&self, duration: Duration) -> Option<i32> {
        self.receiver.recv_timeout(duration).ok()
    }
}

impl Drop for Cancellation {
    fn drop(&mut self) {
        self.handle.close();
        if let Some(worker) = self.worker.take() {
            let _ = worker.join();
        }
    }
}

struct ServerProcess {
    pid: i32,
    args: Vec<String>,
    run_id: Option<String>,
    username: Option<String>,
    password: Option<String>,
}

struct Exclusion {
    pid: Option<i32>,
    run_id: Option<String>,
    tty: Option<String>,
}

impl Exclusion {
    fn detect(state: &State, processes: &[ServerProcess]) -> Self {
        let pid = nonempty_env("WATCHDOG_EXCLUDE_OPENCODE_PID")
            .and_then(|value| value.parse::<i32>().ok())
            .filter(|pid| *pid > 0)
            .or_else(|| ancestor_named(std::process::id() as i32, "opencode"));
        let run_id = nonempty_env("WATCHDOG_EXCLUDE_OPENCODE_RUN_ID")
            .or_else(|| nonempty_env("OPENCODE_RUN_ID"))
            .or_else(|| {
                pid.and_then(|pid| {
                    processes
                        .iter()
                        .find(|process| process.pid == pid)
                        .and_then(|process| process.run_id.clone())
                })
            });
        let tty = nonempty_env("WATCHDOG_EXCLUDE_TTY")
            .and_then(|value| normalize_tty(&value))
            .or_else(|| pid.and_then(|pid| process_tty(state, pid)));
        Self { pid, run_id, tty }
    }

    fn includes(&self, process: &ServerProcess) -> bool {
        Some(process.pid) == self.pid
            || self
                .run_id
                .as_deref()
                .is_some_and(|run_id| process.run_id.as_deref() == Some(run_id))
    }
}

fn positive_u64(value: &str) -> std::result::Result<u64, String> {
    match value.parse::<u64>() {
        Ok(0) => Err("must be at least 1".to_owned()),
        Ok(value) => Ok(value),
        Err(_) => Err("must be a positive integer".to_owned()),
    }
}

fn positive_u32(value: &str) -> std::result::Result<u32, String> {
    match value.parse::<u32>() {
        Ok(0) => Err("must be at least 1".to_owned()),
        Ok(value) => Ok(value),
        Err(_) => Err("must be a positive integer".to_owned()),
    }
}

fn nonempty_env(name: &str) -> Option<String> {
    env::var(name).ok().filter(|value| !value.trim().is_empty())
}

fn lossy_read(path: impl AsRef<Path>) -> String {
    String::from_utf8_lossy(&fs::read(path).unwrap_or_default()).into_owned()
}

fn nul_strings(path: &str) -> Vec<String> {
    fs::read(path)
        .unwrap_or_default()
        .split(|byte| *byte == 0)
        .filter(|value| !value.is_empty())
        .map(|value| String::from_utf8_lossy(value).into_owned())
        .collect()
}

fn env_value(environment: &[u8], name: &[u8]) -> Option<String> {
    environment
        .split(|byte| *byte == 0)
        .find_map(|entry| entry.strip_prefix(name)?.strip_prefix(b"="))
        .map(|value| String::from_utf8_lossy(value).into_owned())
}

fn process_identity(pid: i32) -> Option<(String, i32)> {
    parse_stat(&lossy_read(format!("/proc/{pid}/stat")))
}

fn parse_stat(stat: &str) -> Option<(String, i32)> {
    let open = stat.find('(')?;
    let close = stat.rfind(')')?;
    let mut fields = stat.get(close + 1..)?.split_whitespace();
    fields.next()?;
    let parent = fields.next()?.parse().ok()?;
    Some((stat.get(open + 1..close)?.to_owned(), parent))
}

fn ancestor_named(start: i32, expected: &str) -> Option<i32> {
    let mut pid = start;
    let mut visited = HashSet::new();
    while pid > 1 && visited.insert(pid) {
        let (name, parent) = process_identity(pid)?;
        if name == expected {
            return Some(pid);
        }
        pid = parent;
    }
    None
}

fn server_processes() -> Result<Vec<ServerProcess>> {
    let uid = unsafe { libc::getuid() };
    let mut processes = Vec::new();
    for entry in fs::read_dir("/proc").context("read /proc")?.flatten() {
        let Some(pid) = entry
            .file_name()
            .to_str()
            .and_then(|name| name.parse::<i32>().ok())
        else {
            continue;
        };
        if entry.metadata().ok().map(|metadata| metadata.uid()) != Some(uid)
            || !process_identity(pid).is_some_and(|(name, _)| name == "opencode")
        {
            continue;
        }
        let environment = fs::read(format!("/proc/{pid}/environ")).unwrap_or_default();
        processes.push(ServerProcess {
            pid,
            args: nul_strings(&format!("/proc/{pid}/cmdline")),
            run_id: env_value(&environment, b"OPENCODE_RUN_ID"),
            username: env_value(&environment, b"OPENCODE_SERVER_USERNAME"),
            password: env_value(&environment, b"OPENCODE_SERVER_PASSWORD"),
        });
    }
    processes.sort_by_key(|process| process.pid);
    Ok(processes)
}

fn normalize_tty(tty: &str) -> Option<String> {
    let tty = tty.trim();
    if tty.is_empty() || tty == "?" {
        None
    } else if tty.starts_with("/dev/") {
        Some(tty.to_owned())
    } else {
        Some(format!("/dev/{tty}"))
    }
}

fn drain<R: Read + Send + 'static>(stream: Option<R>) -> JoinHandle<Vec<u8>> {
    thread::spawn(move || {
        let mut bytes = Vec::new();
        if let Some(mut stream) = stream {
            let _ = stream.read_to_end(&mut bytes);
        }
        bytes
    })
}

fn capture_command(state: &State, args: &[String], timeout: Duration) -> Option<String> {
    let (program, arguments) = args.split_first()?;
    let mut child = match Command::new(program)
        .args(arguments)
        .stdout(Stdio::piped())
        .stderr(Stdio::piped())
        .spawn()
    {
        Ok(child) => child,
        Err(error) => {
            state.log(format!("command failed: {}: {error}", args.join(" ")));
            return None;
        }
    };
    let stdout = drain(child.stdout.take());
    let stderr = drain(child.stderr.take());
    let status = match child.wait_timeout(timeout) {
        Ok(Some(status)) => status,
        Ok(None) => {
            terminate_child(&mut child);
            let _ = stdout.join();
            let _ = stderr.join();
            state.log(format!("command failed: {}: timed out", args.join(" ")));
            return None;
        }
        Err(error) => {
            terminate_child(&mut child);
            let _ = stdout.join();
            let _ = stderr.join();
            state.log(format!("command failed: {}: {error}", args.join(" ")));
            return None;
        }
    };
    let output = stdout.join().unwrap_or_default();
    let _ = stderr.join();
    status
        .success()
        .then(|| String::from_utf8_lossy(&output).into_owned())
}

fn process_tty(state: &State, pid: i32) -> Option<String> {
    capture_command(
        state,
        &[
            "/usr/bin/ps".into(),
            "-o".into(),
            "tty=".into(),
            "-p".into(),
            pid.to_string(),
        ],
        Duration::from_secs(5),
    )
    .and_then(|tty| normalize_tty(&tty))
}

fn argument(args: &[String], option: &str) -> Option<String> {
    let joined = format!("{option}=");
    args.iter().enumerate().find_map(|(index, arg)| {
        arg.strip_prefix(&joined).map(str::to_owned).or_else(|| {
            (arg == option)
                .then(|| args.get(index + 1).cloned())
                .flatten()
        })
    })
}

fn probe_host(host: Option<&str>) -> String {
    match host.map(str::trim).filter(|host| !host.is_empty()) {
        None | Some("0.0.0.0" | "::" | "[::]") => "127.0.0.1".to_owned(),
        Some(host) => host.trim_matches(['[', ']']).to_owned(),
    }
}

fn base_url(host: &str, port: u16) -> String {
    if host.contains(':') {
        format!("http://[{host}]:{port}")
    } else {
        format!("http://{host}:{port}")
    }
}

fn tcp_listeners() -> HashMap<String, (String, u16)> {
    lossy_read("/proc/net/tcp")
        .lines()
        .skip(1)
        .filter_map(|line| {
            let fields: Vec<_> = line.split_whitespace().collect();
            if fields.len() < 10 || fields[3] != "0A" {
                return None;
            }
            let (address, port) = fields[1].split_once(':')?;
            let address = u32::from_str_radix(address, 16).ok()?;
            let port = u16::from_str_radix(port, 16).ok()?;
            let host = std::net::Ipv4Addr::from(address.to_le_bytes()).to_string();
            Some((fields[9].to_owned(), (probe_host(Some(&host)), port)))
        })
        .collect()
}

fn process_sockets(pid: i32) -> Vec<String> {
    let Ok(entries) = fs::read_dir(format!("/proc/{pid}/fd")) else {
        return Vec::new();
    };
    entries
        .flatten()
        .filter_map(|entry| fs::read_link(entry.path()).ok())
        .filter_map(|target| {
            let target = target.to_string_lossy();
            target
                .strip_prefix("socket:[")?
                .strip_suffix(']')
                .map(str::to_owned)
        })
        .collect()
}

fn authorization(process: &ServerProcess) -> Option<String> {
    let password = process
        .password
        .clone()
        .or_else(|| nonempty_env("OPENCODE_SERVER_PASSWORD"))?;
    let username = process
        .username
        .clone()
        .or_else(|| nonempty_env("OPENCODE_SERVER_USERNAME"))
        .unwrap_or_else(|| "opencode".to_owned());
    let encoded =
        base64::engine::general_purpose::STANDARD.encode(format!("{username}:{password}"));
    Some(format!("Basic {encoded}"))
}

fn http_client() -> ureq::Agent {
    let config = ureq::Agent::config_builder()
        .timeout_global(Some(Duration::from_secs(2)))
        .build();
    ureq::Agent::new_with_config(config)
}

fn request_json(
    client: &ureq::Agent,
    base_url: &str,
    authorization: Option<&str>,
    path: &str,
) -> Option<Value> {
    let mut request = client
        .get(format!("{}{path}", base_url.trim_end_matches('/')))
        .header("Accept", "application/json");
    if let Some(authorization) = authorization {
        request = request.header("Authorization", authorization);
    }
    let mut response = request.call().ok()?;
    let body = response.body_mut().read_to_string().ok()?;
    serde_json::from_str(&body).ok()
}

fn active_sessions(status: &Value) -> Option<Vec<String>> {
    Some(
        status
            .as_object()?
            .iter()
            .filter_map(|(session, value)| {
                let kind = value
                    .as_object()
                    .and_then(|value| value.get("type"))
                    .and_then(Value::as_str);
                (kind != Some("idle")).then(|| format!("{session}:{}", kind.unwrap_or("unknown")))
            })
            .collect(),
    )
}

fn api_blockers(
    client: &ureq::Agent,
    processes: &[ServerProcess],
    exclusion: &Exclusion,
) -> Vec<String> {
    let listeners = tcp_listeners();
    let mut seen = HashSet::new();
    let mut details = Vec::new();
    for process in processes
        .iter()
        .filter(|process| !exclusion.includes(process))
    {
        let mut urls = Vec::new();
        if let Some(port) = argument(&process.args, "--port").and_then(|port| port.parse().ok()) {
            let host = probe_host(argument(&process.args, "--hostname").as_deref());
            urls.push(base_url(&host, port));
        } else if process.args.iter().any(|arg| arg == "serve") {
            urls.push(base_url("127.0.0.1", 4096));
        }
        urls.extend(
            process_sockets(process.pid)
                .into_iter()
                .filter_map(|inode| {
                    let (host, port) = listeners.get(&inode)?;
                    Some(base_url(host, *port))
                }),
        );
        let authorization = authorization(process);
        for url in urls {
            if !seen.insert((process.pid, url.clone())) {
                continue;
            }
            let health = request_json(client, &url, authorization.as_deref(), "/global/health");
            if health
                .as_ref()
                .and_then(|value| value.get("healthy"))
                .and_then(Value::as_bool)
                != Some(true)
            {
                continue;
            }
            let Some(active) =
                request_json(client, &url, authorization.as_deref(), "/session/status")
                    .as_ref()
                    .and_then(active_sessions)
            else {
                continue;
            };
            if !active.is_empty() {
                details.push(format!(
                    "pid={} {} {}",
                    process.pid,
                    url,
                    active.into_iter().take(4).collect::<Vec<_>>().join(" ")
                ));
            }
        }
    }
    details
}

fn json_text(value: Option<&Value>) -> String {
    match value {
        Some(Value::String(text)) => text.clone(),
        Some(Value::Null) | None => String::new(),
        Some(value) => value.to_string(),
    }
}

fn shortened(text: &str, limit: usize) -> String {
    text.chars().take(limit).collect()
}

fn pane_blockers(state: &State, exclusion: &Exclusion) -> Vec<String> {
    let Some(listing) = capture_command(
        state,
        &[
            "wezterm".into(),
            "cli".into(),
            "list".into(),
            "--format".into(),
            "json".into(),
        ],
        Duration::from_secs(10),
    ) else {
        return Vec::new();
    };
    let panes: Value = match serde_json::from_str(&listing) {
        Ok(value) => value,
        Err(error) => {
            state.log(format!("could not parse wezterm pane list: {error}"));
            return Vec::new();
        }
    };
    let Some(panes) = panes.as_array() else {
        state.log("could not parse wezterm pane list: expected a list");
        return Vec::new();
    };

    let mut details = Vec::new();
    for pane in panes.iter().filter_map(Value::as_object) {
        let tty = normalize_tty(&json_text(pane.get("tty_name")));
        if tty.as_deref() == exclusion.tty.as_deref() && tty.is_some() {
            continue;
        }
        let title = ["title", "tab_title", "window_title"]
            .map(|key| json_text(pane.get(key)))
            .join(" ")
            .trim()
            .to_owned();
        if !title.contains("OC |") && !json_text(pane.get("cwd")).contains("mightyminions") {
            continue;
        }
        let Some(pane_id) = pane.get("pane_id") else {
            state.log("skipping wezterm pane without pane_id");
            continue;
        };
        let pane_id = json_text(Some(pane_id));
        let Some(text) = capture_command(
            state,
            &[
                "wezterm".into(),
                "cli".into(),
                "get-text".into(),
                "--pane-id".into(),
                pane_id.clone(),
                "--start-line".into(),
                "-80".into(),
            ],
            Duration::from_secs(10),
        ) else {
            continue;
        };
        if let Some(line) = text
            .lines()
            .map(str::trim)
            .find(|line| line.to_lowercase().contains(BUSY_PANE_TEXT))
        {
            details.push(format!(
                "pane {pane_id} {} {BUSY_PANE_TEXT} line={:?} title={}",
                tty.as_deref().unwrap_or(""),
                shortened(line, 120),
                shortened(&title, 80)
            ));
        }
    }
    details
}

fn summarize(items: &[String], limit: usize) -> String {
    let mut visible: Vec<_> = items.iter().take(limit).cloned().collect();
    if items.len() > limit {
        visible.push(format!("... +{} more", items.len() - limit));
    }
    visible.join(" | ")
}

fn signal_exit(state: &State, signal: i32) -> i32 {
    state.log(if signal == SIGINT {
        "watchdog interrupted"
    } else {
        "watchdog terminated"
    });
    128 + signal
}

fn wait_until_idle(state: &State, options: &Options) -> Result<i32> {
    let Some(instance) = Instance::acquire(state)? else {
        return Ok(0);
    };
    let cancellation = Cancellation::new()?;
    let initial_processes = server_processes()?;
    let exclusion = Exclusion::detect(state, &initial_processes);
    state.log(format!(
        "watchdog started; excluding opencode pid={} run_id={} tty={}; interval={}s required_idle_checks={}; cache={}",
        exclusion.pid.map(|pid| pid.to_string()).unwrap_or_else(|| "unknown".into()),
        exclusion.run_id.as_deref().unwrap_or("unknown"),
        exclusion.tty.as_deref().unwrap_or("unknown"),
        options.interval,
        options.required_idle_checks,
        state.root.display()
    ));

    let client = http_client();
    let mut consecutive_idle = 0;
    let mut check = 0;
    let signal = loop {
        check += 1;
        let processes = server_processes()?;
        let api_blockers = api_blockers(&client, &processes, &exclusion);
        let pane_blockers = pane_blockers(state, &exclusion);
        consecutive_idle = if api_blockers.is_empty() && pane_blockers.is_empty() {
            consecutive_idle + 1
        } else {
            0
        };
        let sources = [
            (!api_blockers.is_empty()).then_some("opencode API session status"),
            (!pane_blockers.is_empty()).then_some("active pane text"),
        ]
        .into_iter()
        .flatten()
        .collect::<Vec<_>>()
        .join(", ");
        state.log(format!(
            "check {check}: idle={consecutive_idle}/{}; blockers={}",
            options.required_idle_checks,
            if sources.is_empty() { "none" } else { &sources }
        ));
        if !api_blockers.is_empty() {
            state.log(format!(
                "opencode_api_blockers: {}",
                summarize(&api_blockers, 5)
            ));
        }
        if !pane_blockers.is_empty() {
            state.log(format!("pane_blockers: {}", summarize(&pane_blockers, 6)));
        }

        if let Some(signal) = cancellation.wait(Duration::ZERO) {
            break Some(signal);
        }
        if consecutive_idle >= options.required_idle_checks {
            state.log("idle confirmed");
            break None;
        }
        if let Some(signal) = cancellation.wait(Duration::from_secs(options.interval)) {
            break Some(signal);
        }
    };

    drop(instance);
    if let Some(signal) = signal {
        return Ok(signal_exit(state, signal));
    }
    if options.command.is_empty() {
        Ok(0)
    } else {
        Ok(run_command(state, &cancellation, &options.command))
    }
}

fn terminate_child(child: &mut Child) {
    let _ = child.kill();
    let _ = child.wait();
}

fn command_display(command: &[OsString]) -> String {
    command
        .iter()
        .map(|arg| format!("{arg:?}"))
        .collect::<Vec<_>>()
        .join(" ")
}

fn run_command(state: &State, cancellation: &Cancellation, command: &[OsString]) -> i32 {
    state.log(format!("running command: {}", command_display(command)));
    let Some((program, arguments)) = command.split_first() else {
        state.log("could not run command: empty command");
        return 127;
    };
    let mut child = match Command::new(program).args(arguments).spawn() {
        Ok(child) => child,
        Err(error) => {
            state.log(format!("could not run command: {error}"));
            return 127;
        }
    };

    loop {
        match child.try_wait() {
            Ok(Some(status)) => {
                let code = status
                    .code()
                    .or_else(|| status.signal().map(|signal| 128 + signal))
                    .unwrap_or(1);
                state.log(format!("command exited with status {code}"));
                return code;
            }
            Ok(None) => {}
            Err(error) => {
                terminate_child(&mut child);
                state.log(format!("could not wait for command: {error}"));
                return 1;
            }
        }
        if let Some(signal) = cancellation.wait(Duration::from_millis(50)) {
            terminate_child(&mut child);
            return signal_exit(state, signal);
        }
    }
}

fn alive(pid: i32) -> bool {
    pid > 0
        && (unsafe { libc::kill(pid, 0) } == 0
            || io::Error::last_os_error().raw_os_error() == Some(libc::EPERM))
}

fn print_status(state: &State) -> i32 {
    let pid = state.read_pid();
    println!(
        "running={} pid={}",
        pid.is_some_and(alive),
        pid.map(|pid| pid.to_string())
            .unwrap_or_else(|| "unknown".into())
    );
    println!("cache={}", state.root.display());
    println!("log={}", state.log_file.display());
    if let Ok(log) = fs::read_to_string(&state.log_file) {
        let lines: Vec<_> = log.lines().collect();
        if !lines.is_empty() {
            println!("last log lines:");
            for line in &lines[lines.len().saturating_sub(8)..] {
                println!("{line}");
            }
        }
    }
    0
}

fn stop(state: &State) -> i32 {
    let Some(pid) = state.read_pid().filter(|pid| alive(*pid)) else {
        println!("watchdog is not running");
        return 0;
    };
    if unsafe { libc::kill(pid, SIGTERM) } != 0 {
        eprintln!(
            "could not stop watchdog pid={pid}: {}",
            io::Error::last_os_error()
        );
        return 1;
    }
    for _ in 0..50 {
        if !alive(pid) {
            println!("stopped watchdog pid={pid}");
            return 0;
        }
        thread::sleep(Duration::from_millis(100));
    }
    println!("watchdog pid={pid} did not stop after SIGTERM");
    1
}

fn background_arguments(options: &Options) -> Vec<OsString> {
    let mut arguments = vec![
        "--interval".into(),
        options.interval.to_string().into(),
        "--required-idle-checks".into(),
        options.required_idle_checks.to_string().into(),
    ];
    if !options.command.is_empty() {
        arguments.push("--".into());
        arguments.extend(options.command.iter().cloned());
    }
    arguments
}

fn launch_background(state: &State, options: &Options) -> Result<i32> {
    let processes = server_processes()?;
    let exclusion = Exclusion::detect(state, &processes);
    fs::create_dir_all(&state.root)?;
    let mut child = Command::new(env::current_exe().context("locate watchdog executable")?);
    child
        .args(background_arguments(options))
        .stdin(Stdio::null())
        .stdout(Stdio::null())
        .stderr(Stdio::null());
    if let Some(pid) = exclusion.pid {
        child.env("WATCHDOG_EXCLUDE_OPENCODE_PID", pid.to_string());
    }
    if let Some(run_id) = exclusion.run_id {
        child.env("WATCHDOG_EXCLUDE_OPENCODE_RUN_ID", run_id);
    }
    if let Some(tty) = exclusion.tty {
        child.env("WATCHDOG_EXCLUDE_TTY", tty);
    }
    unsafe {
        child.pre_exec(|| {
            if libc::setsid() == -1 {
                Err(io::Error::last_os_error())
            } else {
                Ok(())
            }
        });
    }
    let child = child.spawn().context("start detached watchdog")?;
    println!("started {NAME} pid={}", child.id());
    println!("log={}", state.log_file.display());
    Ok(0)
}

fn execute() -> Result<i32> {
    let options = Options::parse();
    let state = State::discover()?;
    if options.status {
        return Ok(print_status(&state));
    }
    if options.stop {
        return Ok(stop(&state));
    }
    if options.detach {
        return launch_background(&state, &options);
    }
    wait_until_idle(&state, &options)
}

fn main() {
    let code = match execute() {
        Ok(code) => code,
        Err(error) => {
            if let Ok(state) = State::discover() {
                state.log(format!("watchdog crashed: {error:#}"));
            }
            eprintln!("{NAME}: {error:#}");
            1
        }
    };
    std::process::exit(code);
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn parses_proc_stat_with_spaces_and_parentheses() {
        assert_eq!(
            parse_stat("42 (odd ) process) S 7 1 2 3").unwrap(),
            ("odd ) process".to_owned(), 7)
        );
    }

    #[test]
    fn classifies_unknown_session_states_as_active() {
        let status = serde_json::json!({
            "idle": {"type": "idle"},
            "busy": {"type": "busy"},
            "malformed": "oops"
        });
        assert_eq!(
            active_sessions(&status).unwrap(),
            ["busy:busy", "malformed:unknown"]
        );
    }

    #[test]
    fn trailing_command_owns_its_flags() {
        let options =
            Options::try_parse_from([NAME, "--detach", "notify-send", "--detach"]).unwrap();
        assert!(options.detach);
        assert_eq!(options.command, ["notify-send", "--detach"]);
    }

    #[test]
    fn detached_arguments_are_canonical() {
        let options = Options::try_parse_from([
            NAME,
            "--detach",
            "--interval",
            "7",
            "--required-idle-checks",
            "2",
            "notify-send",
            "--detach",
        ])
        .unwrap();
        assert_eq!(
            background_arguments(&options),
            [
                "--interval",
                "7",
                "--required-idle-checks",
                "2",
                "--",
                "notify-send",
                "--detach"
            ]
        );
    }

    #[test]
    fn detached_arguments_keep_separator_for_dash_command() {
        let options = Options::try_parse_from([NAME, "--detach", "--", "--command"]).unwrap();
        assert_eq!(
            background_arguments(&options),
            [
                "--interval",
                "180",
                "--required-idle-checks",
                "3",
                "--",
                "--command"
            ]
        );
    }

    #[test]
    fn rejects_zero_controls() {
        assert!(Options::try_parse_from([NAME, "--interval", "0"]).is_err());
        assert!(Options::try_parse_from([NAME, "--required-idle-checks", "0"]).is_err());
    }

    #[test]
    fn summarizes_overflow() {
        let details = vec!["one".into(), "two".into(), "three".into()];
        assert_eq!(summarize(&details, 2), "one | two | ... +1 more");
    }
}
