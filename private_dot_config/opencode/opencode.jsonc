{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth",
    "@tarquinen/opencode-dcp",
    "opencode-wakatime",
    // "@slkiser/opencode-quota",
    "@tarquinen/opencode-smart-title",
    "opencode-queue",
    "@plannotator/opencode",
    "opencode-goal",
  ],
  "disabled_providers": ["openrouter"],
  "formatter": {
    "rustfmt": {
      "command": ["rustfmt", "$FILE"],
      "extensions": [".rs"],
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
    "cloudflare": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "enabled": false,
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": false,
    },
    "posthog": {
      "type": "remote",
      "url": "https://mcp-eu.posthog.com/mcp",
      "enabled": false,
    },
    "railway": {
      "type": "local",
      "command": ["npx", "-y", "@railway/mcp-server"],
      "enabled": false,
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": false,
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp",
        "--config",
        "/home/mirsella/.config/opencode/playwright-helium.json",
      ],
      "enabled": false,
    },
    "google-drive": {
      "type": "local",
      "command": ["npx", "-y", "@piotr-agier/google-drive-mcp"],
      "enabled": false,
    },
    "planetscale": {
      "type": "remote",
      "url": "https://mcp.pscale.dev/mcp/planetscale",
      "enabled": false,
    },
    "resend": {
      "type": "local",
      "command": ["npx", "-y", "resend-mcp"],
      "enabled": false,
      "environment": {
        "RESEND_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
  },
  "lsp": {
    "rust": {
      "disabled": true,
    },
    "rust-lspmux": {
      "disabled": true,
      "command": ["lspmux", "client"],
      "extensions": [".rs"],
    },
  },
  "permission": {
    "external_directory": "allow",
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5-fast": {
          "variants": {
            "none": {
              "disabled": true,
            },
            "minimal": {
              "disabled": true,
            },
            "medium": {
              "disabled": true,
            },
          },
        },
        "gpt-5.5": {
          "variants": {
            "none": {
              "disabled": true,
            },
            "minimal": {
              "disabled": true,
            },
            "medium": {
              "disabled": true,
            },
          },
        },
        "gpt-5.6-fast": {
          "variants": {
            "none": {
              "disabled": true,
            },
            "minimal": {
              "disabled": true,
            },
            "medium": {
              "disabled": true,
            },
          },
        },
        "gpt-5.6": {
          "variants": {
            "none": {
              "disabled": true,
            },
            "minimal": {
              "disabled": true,
            },
            "medium": {
              "disabled": true,
            },
          },
        },
      },
    },
  },
}
