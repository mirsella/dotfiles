{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth",
    "@tarquinen/opencode-dcp",
    "opencode-wakatime",
    "@howaboua/opencode-usage-plugin",
    "@tarquinen/opencode-smart-title",
    "opencode-queue",
  ],
  "default_agent": "build",
  "agent": {
    "build": {
      "model": "openai/gpt-5.5-fast",
      "reasoningEffort": "medium",
    },
    "plan": {
      "model": "openai/gpt-5.5-fast",
      "reasoningEffort": "xhigh",
    },
  },
  "disabled_providers": ["openrouter"],
  "formatter": {
    "rustfmt": {
      "command": ["rustfmt", "$FILE"],
      "extensions": [".rs"],
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": false,
    },
    "icm": {
      "type": "local",
      "command": ["icm", "serve"],
      "enabled": false,
    },
    "posthog": {
      "type": "remote",
      "url": "https://mcp-eu.posthog.com/mcp",
      "enabled": false,
    },
    "railway": {
      "type": "local",
      "command": ["npx", "-y", "@railway/mcp-server"],
      "enabled": false,
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": false,
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--config",
        "/home/mirsella/.config/opencode/playwright-helium.json",
      ],
      "enabled": false,
    },
    "google-drive": {
      "type": "local",
      "command": ["npx", "-y", "@piotr-agier/google-drive-mcp@latest"],
      "enabled": false,
    },
  },
  "lsp": {
    "rust": {
      "disabled": true,
    },
    "rust-lspmux": {
      "command": ["lspmux", "client"],
      "extensions": [".rs"],
    },
  },
  "permission": {
    "external_directory": "allow",
    "bash": {
      "sudo*": "ask",
      "chmod*": "ask",
      "chown*": "ask",
      "paru*": "ask",
      "pacman*": "ask",
    },
  },
}
